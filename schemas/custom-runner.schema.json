{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charly.dev/espectacular/custom-runner.schema.json",
  "title": "ah custom runner envelope",
  "description": "Envelope emitted by a configured custom runner. findings[] reuses the ah finding shape from check-output.schema.json.",
  "type": "object",
  "required": ["exit_code", "passed", "findings"],
  "additionalProperties": false,
  "properties": {
    "exit_code": {
      "type": "integer"
    },
    "passed": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "https://charly.dev/espectacular/check-output.schema.json#/$defs/finding" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "passed": { "const": true } },
        "required": ["passed"]
      },
      "then": {
        "properties": { "findings": { "maxItems": 0 } }
      },
      "else": {
        "properties": { "findings": { "minItems": 1 } }
      }
    }
  ]
}
