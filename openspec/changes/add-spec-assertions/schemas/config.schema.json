{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charly.dev/espectacular/config.schema.json",
  "title": "espectacular config",
  "type": "object",
  "required": ["tool_version", "paths", "runners"],
  "additionalProperties": false,
  "properties": {
    "tool_version": { "type": "string", "minLength": 1 },
    "paths": {
      "type": "object",
      "required": ["specs", "changes"],
      "additionalProperties": false,
      "properties": {
        "specs": { "type": "string", "minLength": 1 },
        "changes": { "type": "string", "minLength": 1 }
      }
    },
    "runners": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      }
    }
  }
}
